# Create .env.local from this file. Never commit a real API key.
GEMINI_API_KEY=replace-with-a-new-key
GEMINI_MODEL=gemini-2.5-flash
SHOTAI_API_PORT=8787
SHOTAI_API_HOST=127.0.0.1
SHOTAI_WEB_ORIGIN=http://127.0.0.1:5173
GEMINI_TIMEOUT_MS=25000
RATE_LIMIT_MAX=30

# Optional: required when Gemini cannot be reached directly.
# Clash users can usually use the HTTP/mixed port below.
HTTPS_PROXY=http://127.0.0.1:7897
HTTP_PROXY=http://127.0.0.1:7897
NO_PROXY=127.0.0.1,localhost
